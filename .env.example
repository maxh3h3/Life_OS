# ── Telegram ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_personal_chat_id_here

# ── Anthropic / Claude ─────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# ── App ────────────────────────────────────────────────
USER_NAME=YourFirstName
NODE_ENV=production
## you must use IANA timezone identifiers
## https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Continent/City

# ── Webhook ────────────────────────────────────────────
# Set WEBHOOK_URL to enable webhook mode (production).
# Leave commented out to use long polling (local dev).
WEBHOOK_URL=https://yourdomain.com
WEBHOOK_SECRET=replace-with-a-long-random-string
PORT=3000
